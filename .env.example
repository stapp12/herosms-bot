# ── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── HeroSMS API ───────────────────────────────────────────────────────────────
HEROSMS_API_KEY=your_herosms_api_key_here

# ── Pricing / Markup ──────────────────────────────────────────────────────────
# Flat markup in USD added to every number price:
MARKUP=0.10
# OR percentage markup (set to 0 to use flat MARKUP instead):
MARKUP_PCT=0

# ── Admins ────────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs of admins:
ADMIN_IDS=123456789,987654321

# ── Crypto payments (NOWPayments) ─────────────────────────────────────────────
# Get your key at https://nowpayments.io
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=herosms_bot.db
